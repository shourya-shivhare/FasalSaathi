GOOGLE_API_KEY=your-google-ai-api-key
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.3
CHROMA_PERSIST_DIR=./chroma_db

# ── YOLO Pest Detection ───────────────────────────────────────────────────────
# Path to trained weights (relative to project root)
YOLO_WEIGHTS_PATH=models/best.pt
# Minimum confidence for a detection to be reported (0.0 – 1.0)
YOLO_CONF_THRESHOLD=0.35
# Directory where annotated result images are saved
YOLO_OUTPUT_DIR=outputs/detections
